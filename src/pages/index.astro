---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<BaseLayout title="Liam James | Sales & GTM Leader" description="Fractional CRO, GTM strategy, and sales leadership. Helping B2B companies build scalable revenue engines.">

    <!-- Hero -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <p class="hero-label">Sales & GTM Leader</p>
                <h1 class="hero-title">I help startups build <span class="gradient-text">scalable revenue engines</span></h1>
                <p class="hero-subtitle">I partner with startups to build the sales systems, GTM motions, and team structures they need to turn early traction into repeatable, scalable revenue.</p>
                <div class="hero-actions">
                    <a href="#contact" class="btn btn-primary">Book a Call</a>
                    <a href="#services" class="btn btn-outline">View Services</a>
                </div>
            </div>
            <div class="hero-image">
                <img src="/assets/headshot.jpeg" alt="Liam James" class="headshot">
            </div>
        </div>
    </section>

    <!-- About -->
    <section id="about" class="section">
        <div class="container">
            <p class="section-label" style="text-align:center">About</p>
            <div class="about-grid">
                <div class="about-text">
                    <h2>Always building, personally and professionally.</h2>
                    <p>English by birth, Latvian by choice. I swapped London's private medical sales floors for Riga, picked up a coaching career in English along the way, and eventually landed in SaaS &mdash; where I've been ever since.</p>
                    <p>Most of my career has been spent at the sharp end of revenue: building sales teams, designing enablement programmes, and figuring out what actually makes deals close. Five years at Lokalise taught me what good looks like &mdash; from running a team of AEs to shaping how an entire sales org learns, sells, and wins.</p>
                    <p>These days I'm a dad, a founder, a GTM advisor, and on a good weekend, a half-decent carpenter. I run <strong>Globalize</strong>, advise startups on go-to-market, and work with founders who are ready to turn early traction into something repeatable.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="services" class="section section-alt">
        <div class="container">
            <p class="section-label">Services</p>
            <h2 class="section-title">How I can help</h2>
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
                    </div>
                    <h3>Fractional Sales Leader</h3>
                    <p>Embed senior revenue leadership into your business without the full-time cost. I'll own your revenue strategy, align sales with company goals, and build the systems your team needs to scale.</p>
                    <ul class="service-list">
                        <li>Revenue strategy & forecasting</li>
                        <li>Sales team structure & hiring</li>
                        <li>Pipeline management & deal review</li>
                        <li>Board & investor reporting</li>
                    </ul>
                </div>
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                    </div>
                    <h3>GTM Strategy & Execution</h3>
                    <p>Go-to-market isn't just a launch plan &mdash; it's the system that turns your product into revenue. I'll help you define your ICP, build your sales motion, and create a playbook your team can run.</p>
                    <ul class="service-list">
                        <li>ICP & market segmentation</li>
                        <li>Sales process design</li>
                        <li>Messaging & positioning</li>
                        <li>Channel & partnership strategy</li>
                    </ul>
                </div>
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <h3>Sales Enablement</h3>
                    <p>Your reps are only as good as the systems behind them. I build onboarding programmes, training frameworks, and sales collateral that turn average performers into consistent closers.</p>
                    <ul class="service-list">
                        <li>Onboarding & ramp programmes</li>
                        <li>Sales playbooks & battle cards</li>
                        <li>Coaching & performance frameworks</li>
                        <li>Tool stack optimisation</li>
                    </ul>
                </div>
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                    </div>
                    <h3>Partnership Development</h3>
                    <p>Partnerships that drive revenue, not just logos on a page. I design and build partner programmes that create real pipeline and mutual growth.</p>
                    <ul class="service-list">
                        <li>Partner programme design</li>
                        <li>Co-sell & co-marketing motions</li>
                        <li>Partner enablement & onboarding</li>
                        <li>Revenue attribution & tracking</li>
                    </ul>
                </div>
            </div>
            <p style="color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7; margin-top: 48px; text-align: center;">I use an internal platform called <a href="/gotomar" style="color: var(--color-accent-light); font-weight: 500;">Gotomar</a> to deliver AI-powered go-to-market playbooks &mdash; customised to your product, market, and stage.</p>
        </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="section">
        <div class="container">
            <p class="section-label">Experience</p>
            <h2 class="section-title">Where I've built</h2>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>Sales & Business Advisor</h3>
                                <p class="timeline-company">Fractional</p>
                            </div>
                            <span class="timeline-date">Ongoing</span>
                        </div>
                        <p>Working with select B2B companies as a fractional CRO and GTM advisor &mdash; helping founders and leadership teams build repeatable sales processes, hire and coach teams, and turn early traction into scalable revenue.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>AE Team Lead &rarr; Sales Manager &rarr; Sales Enablement Lead</h3>
                                <p class="timeline-company">Lokalise</p>
                            </div>
                            <span class="timeline-date">2020 &ndash; 2025</span>
                        </div>
                        <p>Five years growing with one of the leading localization platforms. Started as an AE Team Lead hitting 120% of quota and managing strategic enterprise deals. Progressed to Sales Manager &mdash; recruiting, training, and leading a team of reps while owning strategy and forecasting. Moved into Sales Enablement Lead, building onboarding programmes, sales collateral, and training frameworks that raised the bar across the entire sales org.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>Sales & Partnerships Manager</h3>
                                <p class="timeline-company">tem energy</p>
                            </div>
                            <span class="timeline-date">2025 &ndash; 2026</span>
                        </div>
                        <p>Led sales and partnership growth at an AI-powered energy platform. Built scalable GTM systems with repeatable sales processes and partnership programmes. Coached the commercial team on strategic, consultative selling and partnered cross-functionally with Product, Marketing, and Design.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>GTM Advisor</h3>
                                <p class="timeline-company">Edge Energy</p>
                            </div>
                            <span class="timeline-date">Current</span>
                        </div>
                        <p>Advising this AI-powered energy brokerage on go-to-market strategy &mdash; from ICP definition and sales process design to channel partnerships and market positioning. Helping UK businesses cut energy costs by up to 30%.</p>
                        <a href="https://edge-energy.uk" target="_blank" rel="noopener" class="venture-link">edge-energy.uk &rarr;</a>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>CEO & Founder</h3>
                                <p class="timeline-company">Globalize</p>
                            </div>
                            <span class="timeline-date">Current</span>
                        </div>
                        <p>Building an AI-powered localization platform for developers. Globalize helps software teams ship multilingual products faster by automating translation workflows and integrating directly into the development pipeline &mdash; no manual handoffs, no spreadsheets, no delays.</p>
                        <a href="https://globalize.now" target="_blank" rel="noopener" class="venture-link">globalize.now &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Latest from the blog -->
    {latestPosts.length > 0 && (
    <section class="section section-alt">
        <div class="container">
            <p class="section-label">Blog</p>
            <h2 class="section-title">Latest from the blog</h2>
            <div class="blog-grid">
                {latestPosts.map((post) => (
                    <a href={`/blog/${post.id}`} class="blog-card">
                        <span class="blog-card-date">
                            {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                        </span>
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                        <div class="blog-card-tags">
                            {post.data.tags.slice(0, 3).map((tag: string) => (
                                <span class="blog-tag">{tag}</span>
                            ))}
                        </div>
                    </a>
                ))}
            </div>
            <div style="text-align: center; margin-top: 40px;">
                <a href="/blog" class="btn btn-outline">View all posts</a>
            </div>
        </div>
    </section>
    )}

    <!-- Contact -->
    <section id="contact" class="section section-alt">
        <div class="container">
            <div class="contact-inner">
                <p class="section-label">Get in Touch</p>
                <h2 class="section-title">Let's talk revenue.</h2>
                <p class="contact-subtitle">Whether you need a fractional sales leader, GTM strategy, or just a sounding board for your next sales hire &mdash; I'd love to hear from you.</p>
                <div class="contact-methods">
                    <a href="https://cal.com/liam-james/30min" class="btn btn-primary">Book a Call</a>
                    <a href="https://www.linkedin.com/in/ljak/" target="_blank" rel="noopener" class="btn btn-outline">LinkedIn</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>
