---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Thanks for your purchase — Liam James" description="Your guide is on its way.">
  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container">
      <div style="text-align: center; max-width: 560px; margin: 0 auto;">
        <h1 class="section-title">Thanks for the purchase.</h1>
        <p style="color: var(--color-text-muted); font-size: 1.1rem; line-height: 1.7; margin-bottom: 2rem;">
          Check your email — the guide should arrive within a few minutes. If you don't see it, check spam or reach out to me directly.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center;">
          <a href="/guides" class="btn btn-outline">Back to guides</a>
          <a href="/" class="btn btn-primary">Home</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
